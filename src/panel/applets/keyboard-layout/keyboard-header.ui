<interface>
  <template class="KeyboardHeader" parent="GtkBox">
    <style>
      <class name="bluetooth-header"/>
    </style>
    <property name="orientation">GTK_ORIENTATION_HORIZONTAL</property>
    <property name="spacing">0</property>
    <property name="margin-start">4</property>
    <property name="margin-end">4</property>
    <child>
      <object class="GtkLabel" id="label">
        <style>
          <class name="dim-label"/>
        </style>
        <property name="margin-start">4</property>
        <property name="halign">GTK_ALIGN_START</property>
        <property name="label" translatable="yes">Keyboard Layout</property>
        <attributes>
          <attribute name="weight" value="bold"/>
        </attributes>
      </object>
      <packing>
        <property name="expand">True</property>
        <property name="fill">True</property>
      </packing>
    </child>
    <child>
      <object class="GtkButton" id="button">
        <style>
          <class name="flat"/>
        </style>
        <property name="image">image</property>
        <property name="tooltip-text" translatable="yes">Keyboard Layout Settings</property>
        <signal name="clicked" handler="keyboard_header_button_clicked_cb"/>
      </object>
    </child>
    <child>
      <object class="GtkImage" id="image">
        <property name="icon-name">preferences-system-symbolic</property>
      </object>
    </child>
  </template>
</interface>
